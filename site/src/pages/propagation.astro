---
import Layout from "@/components/Layout.astro";
import PassageBrowser from "@/islands/PassageBrowser.svelte";
import ReadingLink from "@/components/ReadingLink.astro";
import { propagation, agencies } from "@/lib/load";
import { statementPath, withBase } from "@/lib/paths";
import { originalityPercent } from "@/lib/format";

const nameByAbbr = new Map(agencies.map((a) => [a.abbr, a.name]));
const names = Object.fromEntries(nameByAbbr);
const board = propagation.originality;
const clusters = propagation.clusters;
const templateClusters = clusters.filter((c) => c.alsoInDta).length;

// Spell out the template source on first mention — a newcomer won't know "DTA".
const ursource = propagation.ursource;
const ursourceName = nameByAbbr.get(ursource) ?? ursource;
const ursourceLabel = ursourceName === ursource ? ursource : `${ursourceName} (${ursource})`;

const mostBespoke = board.slice(0, 8);
const mostTemplated = board.slice(-8).reverse();

const columns = [
  { heading: "Most bespoke", rows: mostBespoke },
  { heading: "Most templated", rows: mostTemplated },
];
---

<Layout
  title="Propagation"
  description="How a shared template spreads across Australian Government AI transparency statements — an originality leaderboard and a browser of the passages agencies copy."
>
  <div class="page stack">
    <header class="stack">
      <h1>The template effect</h1>
      <p class="lede">
        Many agencies start from the same template, published by the {ursourceLabel},
        then edit. This shows how much each statement is bespoke versus shared, and
        lets you browse the exact passages that recur &mdash; {templateClusters} of them
        also appear in the {ursource}&rsquo;s own statement.
      </p>
    </header>

    <section>
      <div class="section-title">
        <h2>Originality leaderboard</h2>
        <span class="section-title__links">
          <ReadingLink anchor="originality" />
          <a href={withBase("/agencies")}>All {board.length} ranked &rarr;</a>
        </span>
      </div>
      <div class="boards">
        {
          columns.map((col) => (
            <div class="board">
              <h3 class="board__heading">{col.heading}</h3>
              <ol class="board__list">
                {col.rows.map((e) => (
                  <li class="board__row">
                    <a class="board__name" href={statementPath(e.abbr)}>
                      {nameByAbbr.get(e.abbr) ?? e.abbr}
                    </a>
                    <span class="board__bar" role="presentation">
                      <span style={`inline-size:${originalityPercent(e.score)}%`} />
                    </span>
                    <span class="board__pct mono">{originalityPercent(e.score)}%</span>
                  </li>
                ))}
              </ol>
            </div>
          ))
        }
      </div>
    </section>

    <section>
      <div class="section-title">
        <h2>Shared passages</h2>
        <span class="section-title__links">
          <ReadingLink anchor="reuse" />
          <span class="muted">{clusters.length} clusters</span>
        </span>
      </div>
      <p class="muted shared-note">
        Passages that recur across statements, widest reach first. The {ursource} publishes
        the canonical template, so passages also found there are marked.
      </p>
      <PassageBrowser client:idle names={names} />
    </section>
  </div>
</Layout>

<style>
  .section-title__links {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-4);
  }

  .boards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: var(--space-5) var(--space-8);
  }

  .board__heading {
    font-size: 1rem;
    margin: 0 0 var(--space-2);
    color: var(--muted);
  }

  .board__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .board__row {
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) minmax(4rem, 9rem) 3rem;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-1);
  }

  .board__name {
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .board__name:hover {
    color: var(--accent-ink);
  }

  /* ink fill (bespoke) on an ochre track (borrowed), so the bar reads itself */
  .board__bar {
    block-size: 0.55rem;
    background: var(--heat-2);
    border-radius: 999px;
    overflow: hidden;
  }

  .board__bar span {
    display: block;
    block-size: 100%;
    background: var(--text);
    border-radius: 999px;
  }

  .board__pct {
    font-size: 0.8rem;
    color: var(--muted);
    text-align: end;
  }

  .shared-note {
    max-width: var(--measure);
    margin-block-end: var(--space-4);
  }

  @media (width < 34rem) {
    .board__row {
      grid-template-columns: 1fr 3rem;
    }

    .board__bar {
      display: none;
    }
  }
</style>
