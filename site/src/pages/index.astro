---
import Layout from "@/components/Layout.astro";
import CoverageStats from "@/components/CoverageStats.astro";
import AgencyWall from "@/components/AgencyWall.astro";
import AgencyFinder from "@/islands/AgencyFinder.svelte";
import { getTimeline, meta, propagation, getAgencies } from "@/lib/load";
import { formatDate } from "@/lib/format";
import { withBase, statementPath } from "@/lib/paths";

const timeline = await getTimeline();
const agencies = await getAgencies();

// One row per agency (their most recent genuine change) so a single daily-churning
// statement doesn't crowd out the feed.
const seen = new Set<string>();
const recent = timeline
  .filter((e) => e.kind === "updated" && !e.isNoise)
  .filter((e) => !seen.has(e.abbr) && seen.add(e.abbr))
  .slice(0, 10);

const c = meta.counts;
const finderAgencies = agencies.map((a) => ({
  abbr: a.abbr,
  name: a.name,
  status: a.status,
}));
const explorers = [
  {
    href: withBase("/timeline"),
    title: "Timeline",
    hint: `${c.revisions} changes`,
    body: "Every change to every statement, newest first, down to the words that moved.",
  },
  {
    href: withBase("/agencies"),
    title: "Agencies",
    hint: `${c.published} / ${c.agencies}`,
    body: "Who has published, who hasn't, and who sits outside the mandate.",
  },
  {
    href: withBase("/similarity"),
    title: "Similarity",
    hint: `${c.embedded} mapped`,
    body: "A map of which statements read alike, from sentence-embedding distances.",
  },
  {
    href: withBase("/propagation"),
    title: "Propagation",
    hint: `${propagation.clusters.length} clusters`,
    body: "How one DTA template bleeds across agencies, and who wrote their own.",
  },
];
---

<Layout title="AI Transparency Tracker">
  <div class="page home">
    <header class="hero">
      <p class="hero__dateline mono">Tracking {c.agencies} agencies · rescraped daily</p>
      <h1 class="hero__title">How the Australian Government talks about its use of AI</h1>
      <p class="lede hero__lede">
        Since February 2025, Commonwealth agencies must publish AI transparency
        statements. This tracker scrapes them every day and records every change in
        git, so you can watch the statements evolve, see which read alike, and trace
        the template language that spreads between them.
      </p>
    </header>

    <div class="home__finder">
      <AgencyFinder client:load agencies={finderAgencies} />
    </div>

    <div class="home__wall">
      <p class="home__wall-caption">
        Each square is one agency, shaded by how much of its statement is its own
        words (<strong>bespoke</strong>) versus shared template language
        (<strong>borrowed</strong>). Hover or tap one to read it.
      </p>
      <AgencyWall />
    </div>

    <CoverageStats />

    <section class="recent" aria-labelledby="recent-heading">
      <div class="section-title">
        <h2 id="recent-heading">Recent changes</h2>
        <a href={withBase("/timeline")}>Full timeline &rarr;</a>
      </div>
      <ul class="feed">
        {
          recent.map((e) => (
            <li class="feed__row">
              <time class="feed__date mono" datetime={e.date}>
                {formatDate(e.date)}
              </time>
              <a class="feed__agency" href={statementPath(e.abbr)}>
                {e.agency}
              </a>
              <span class="feed__abbr mono">{e.abbr}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="explore" aria-labelledby="explore-heading">
      <div class="section-title">
        <h2 id="explore-heading">Explore</h2>
      </div>
      <ul class="directory">
        {
          explorers.map((x) => (
            <li>
              <a class="directory__link" href={x.href}>
                <span class="directory__head">
                  <span class="directory__title">{x.title}</span>
                  <span class="directory__hint mono">{x.hint}</span>
                </span>
                <span class="directory__body">{x.body}</span>
                <span class="directory__arrow" aria-hidden="true">
                  &rarr;
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Layout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: var(--space-section);
  }

  /* --- hero --- */
  .hero {
    max-width: 56rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-block-start: var(--space-2);
  }

  .hero__dateline {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--accent-ink);
    letter-spacing: 0.01em;
  }

  .hero__title {
    font-size: var(--display);
    font-weight: 800;
    font-stretch: 86%;
    line-height: 0.98;
    letter-spacing: -0.03em;
    max-width: 18ch;
  }

  .hero__lede {
    margin: 0;
    max-width: 54ch;
  }

  .home__finder {
    margin-block-start: calc(-1 * var(--space-6));
  }

  .home__wall {
    margin-block-start: calc(-1 * var(--space-4));
  }

  .home__wall-caption {
    margin: 0 0 var(--space-4);
    max-inline-size: var(--measure);
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .home__wall-caption strong {
    color: var(--text);
    font-weight: 600;
  }

  /* --- recent changes feed --- */
  .feed {
    list-style: none;
    margin: 0;
    padding: 0;
    border-block-start: 1px solid var(--border);
  }

  .feed__row {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-3);
    margin-inline: calc(-1 * var(--space-3));
    border-block-end: 1px solid var(--border);
    transition: background var(--dur-fast) var(--ease-out-quart);
  }

  .feed__row:hover {
    background: var(--surface);
  }

  .feed__date {
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .feed__agency {
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
  }

  .feed__row:hover .feed__agency {
    color: var(--accent-ink);
  }

  .feed__abbr {
    font-size: var(--text-sm);
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  /* --- explore directory --- */
  .directory {
    list-style: none;
    margin: 0;
    padding: 0;
    border-block-start: 1px solid var(--border-strong);
  }

  .directory__link {
    display: grid;
    grid-template-columns: minmax(11rem, 0.5fr) 1fr auto;
    align-items: baseline;
    gap: var(--space-3) var(--space-6);
    padding-block: var(--space-4);
    border-block-end: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
  }

  .directory__head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .directory__title {
    font-size: var(--text-xl);
    font-weight: 720;
    font-stretch: 96%;
    letter-spacing: -0.01em;
    transition: color var(--dur-fast) var(--ease-out-quart);
  }

  .directory__hint {
    font-size: var(--text-sm);
    color: var(--accent-ink);
    white-space: nowrap;
  }

  .directory__body {
    color: var(--muted);
    font-size: 0.95rem;
    text-wrap: pretty;
  }

  .directory__arrow {
    font-size: 1.3rem;
    color: var(--accent);
    justify-self: end;
    transition: transform var(--dur) var(--ease-out-expo);
  }

  .directory__link:hover .directory__title {
    color: var(--accent-ink);
  }

  .directory__link:hover .directory__arrow {
    transform: translateX(0.35rem);
  }

  @media (width < 40rem) {
    .directory__link {
      grid-template-columns: 1fr auto;
    }

    .directory__body {
      grid-column: 1 / -1;
      grid-row: 2;
    }
  }

  @media (width < 34rem) {
    .feed__row {
      grid-template-columns: 1fr auto;
    }

    .feed__date {
      grid-column: 1 / -1;
    }
  }

  /* --- one orchestrated entrance on load (reduced-motion falls back instantly
     via the global rule that collapses animation duration) --- */
  @media (prefers-reduced-motion: no-preference) {
    .hero__dateline,
    .hero__title,
    .hero__lede,
    .home__finder,
    .home__wall {
      animation: rise var(--dur-slow) var(--ease-out-expo) both;
    }

    .hero__title {
      animation-delay: 0.06s;
    }
    .hero__lede {
      animation-delay: 0.12s;
    }
    .home__finder {
      animation-delay: 0.18s;
    }
    .home__wall {
      animation-delay: 0.24s;
    }
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(0.7rem);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>
