---
// The register, as one image: a cell per tracked agency, coloured by how much of
// its statement is borrowed from the DTA template (deep ochre) versus bespoke
// (ink). Published cells link through; gaps and exemptions read as absences. The
// agencies table is the accessible canonical list — this is the overview on top.
import { getAgencies } from "@/lib/load";
import { statementPath } from "@/lib/paths";
import { originalityPercent } from "@/lib/format";
import ReadingLink from "@/components/ReadingLink.astro";

const agencies = await getAgencies();
const byName = (a: { name: string }, b: { name: string }) => a.name.localeCompare(b.name);

// Templated-ness (1 − originality) → a 0–4 ochre step, matching the passage heat.
function cellHeat(status: string, originality: number | null): number {
  if (status !== "published" || originality === null) return 0;
  const t = 1 - originality;
  return t < 0.3 ? 0 : t < 0.55 ? 1 : t < 0.75 ? 2 : t < 0.9 ? 3 : 4;
}

function cellLabel(name: string, status: string, originality: number | null): string {
  if (status === "not-yet") return `${name} — not yet published`;
  if (status === "exempt") return `${name} — exempt or out of scope`;
  if (originality === null) return `${name} — published`;
  return `${name} — ${originalityPercent(originality)}% bespoke`;
}

const cells = agencies.toSorted(byName).map((a) => ({
  abbr: a.abbr,
  status: a.status,
  heat: cellHeat(a.status, a.originality),
  label: cellLabel(a.name, a.status, a.originality),
  href: a.status === "published" ? statementPath(a.abbr) : null,
}));
---

<figure class="wall">
  <ul class="wall__grid" role="list">
    {
      cells.map((c) => (
        <li data-label={c.label}>
          {c.href ? (
            <a class="wall__cell" data-status={c.status} data-heat={c.heat} href={c.href} aria-label={c.label} />
          ) : (
            <span class="wall__cell" data-status={c.status} aria-label={c.label} role="img" />
          )}
        </li>
      ))
    }
  </ul>

  <p
    class="wall__readout"
    aria-hidden="true"
    data-hint="Point at, focus, or tap a square to name its agency"
  >
    Point at, focus, or tap a square to name its agency
  </p>

  <figcaption class="wall__legend">
    <span class="wall__scale">
      <span class="wall__key" data-heat="0" aria-hidden="true" /> bespoke
      <span class="wall__key" data-heat="2" aria-hidden="true" />
      <span class="wall__key" data-heat="4" aria-hidden="true" /> borrowed
    </span>
    <span class="wall__sep" aria-hidden="true">·</span>
    <span><span class="wall__key" data-status="not-yet" aria-hidden="true" /> not yet</span>
    <span><span class="wall__key" data-status="exempt" aria-hidden="true" /> exempt</span>
    <ReadingLink anchor="originality" label="What is bespoke?" class="wall__how" />
  </figcaption>
</figure>

<style>
  .wall {
    margin: 0;
  }

  .wall__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(1.45rem, 1fr));
    gap: 0.32rem;
  }

  /* On touch, widen the tracks so each published cell is a ≥24px tap target
     (WCAG 2.5.8); on the narrowest screens the cells otherwise hit their min. */
  @media (pointer: coarse) {
    .wall__grid {
      grid-template-columns: repeat(auto-fill, minmax(1.6rem, 1fr));
    }
  }

  .wall__cell {
    display: block;
    aspect-ratio: 1;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface-2);
    text-decoration: none;
  }

  /* published, bespoke: inky neutral (their own words) */
  .wall__cell[data-status="published"][data-heat="0"] {
    background: color-mix(in oklab, var(--text) 16%, var(--surface));
    border-color: color-mix(in oklab, var(--text) 22%, var(--border));
  }

  .wall__cell[data-heat="1"] {
    background: var(--heat-1);
  }
  .wall__cell[data-heat="2"] {
    background: var(--heat-2);
  }
  .wall__cell[data-heat="3"] {
    background: var(--heat-3);
  }
  .wall__cell[data-heat="4"] {
    background: var(--heat-4);
    border-color: color-mix(in oklab, var(--accent) 50%, var(--border));
  }

  .wall__cell[data-status="not-yet"] {
    background: transparent;
    border: 1.5px dashed var(--border-strong);
  }

  .wall__cell[data-status="exempt"] {
    background: var(--surface);
    opacity: 0.5;
  }

  a.wall__cell {
    transition:
      transform var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart);
  }

  a.wall__cell:hover {
    transform: scale(1.2);
    border-color: var(--accent-ink);
    z-index: 1;
  }

  a.wall__cell:focus-visible {
    transform: scale(1.2);
    z-index: 1;
  }

  /* Desktop locality: a floating label tethered to the hovered/focused cell.
     The pseudo-element lives on the <li> (not the cell) so the cell's scale
     transform doesn't drag it; :has() lifts the whole li above its neighbours
     while the label is up. Touch devices get the readout below instead. */
  .wall__grid > li {
    position: relative;
  }

  .wall__grid > li:has(.wall__cell:hover),
  .wall__grid > li:has(.wall__cell:focus-visible) {
    z-index: 2;
  }

  .wall__grid > li::after {
    content: attr(data-label);
    position: absolute;
    bottom: calc(100% + 0.45rem);
    left: 50%;
    width: max-content;
    max-width: 14rem;
    padding: 0.3rem 0.5rem;
    border-radius: var(--radius-sm);
    background: var(--text);
    color: var(--surface);
    font-size: var(--text-sm);
    line-height: 1.3;
    text-align: center;
    box-shadow: var(--shadow-lg);
    opacity: 0;
    transform: translateX(-50%) translateY(0.2rem);
    transition:
      opacity var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart);
    pointer-events: none;
  }

  .wall__grid > li:has(.wall__cell:hover)::after,
  .wall__grid > li:has(.wall__cell:focus-visible)::after {
    opacity: 1;
    transform: translateX(-50%);
  }

  /* No hover label on touch — it can't be dismissed and the readout covers it. */
  @media (hover: none) {
    .wall__grid > li::after {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wall__grid > li::after {
      transition: none;
    }
  }

  .wall__readout {
    margin: var(--space-3) 0 0;
    min-height: 1.4em;
    font-size: var(--text-sm);
    color: var(--text);
  }

  .wall__legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-4);
    margin-block-start: var(--space-3);
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .wall__scale {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .wall__how {
    margin-inline-start: auto;
  }

  .wall__sep {
    color: var(--border-strong);
  }

  .wall__key {
    display: inline-block;
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 3px;
    border: 1px solid var(--border);
    vertical-align: -0.12em;
  }

  .wall__key[data-heat="0"] {
    background: color-mix(in oklab, var(--text) 16%, var(--surface));
  }
  .wall__key[data-heat="2"] {
    background: var(--heat-2);
  }
  .wall__key[data-heat="4"] {
    background: var(--heat-4);
  }
  .wall__key[data-status="not-yet"] {
    background: transparent;
    border: 1.5px dashed var(--border-strong);
  }
  .wall__key[data-status="exempt"] {
    background: var(--surface);
    opacity: 0.6;
  }

  /* The cell colour is the data (bespoke ink → borrowed ochre); keep it under
     forced colours instead of letting every cell flatten to one system colour. */
  @media (forced-colors: active) {
    .wall__cell,
    .wall__key {
      forced-color-adjust: none;
    }
  }
</style>

<script>
  // Live readout: name the agency under the pointer / focus / finger. This is the
  // touch story (native title is invisible on touch) and the keyboard story; the
  // CSS ::after label handles desktop pointer locality on top.
  for (const wall of document.querySelectorAll<HTMLElement>(".wall")) {
    const grid = wall.querySelector<HTMLElement>(".wall__grid");
    const readout = wall.querySelector<HTMLElement>(".wall__readout");
    if (!grid || !readout) continue;

    const hint = readout.dataset.hint ?? readout.textContent ?? "";
    const name = (target: EventTarget | null) =>
      (target instanceof Element ? target.closest<HTMLElement>("li[data-label]") : null)?.dataset.label;

    const show = (target: EventTarget | null) => {
      const label = name(target);
      if (label) readout.textContent = label;
    };

    grid.addEventListener("pointerover", (e) => show(e.target));
    grid.addEventListener("focusin", (e) => show(e.target));

    // Mouse leaving the wall restores the hint; a lifted finger keeps the last
    // name visible (touch has nowhere else to read it). Keyboard restores only
    // when focus genuinely leaves the grid, so tabbing between cells won't flicker.
    grid.addEventListener("pointerleave", (e) => {
      if (e.pointerType !== "touch") readout.textContent = hint;
    });
    grid.addEventListener("focusout", (e) => {
      if (!grid.contains(e.relatedTarget as Node | null)) readout.textContent = hint;
    });
  }
</script>
