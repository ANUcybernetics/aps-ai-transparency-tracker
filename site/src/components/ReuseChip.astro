---
// A small count chip appended to a highlighted (reused) passage. Hovering or
// focusing it reveals which OTHER agencies share the same passage, as links to
// their statements. Pure CSS reveal (:hover / :focus-within) — no JS, no
// dependencies — so it works on the otherwise-static statement page and keeps
// the panel hoverable and keyboard-reachable (WCAG 1.4.13).
import { statementPath } from "@/lib/paths";

interface Member {
  abbr: string;
  name: string;
}

interface Props {
  members: Member[];
}

const { members } = Astro.props;
const n = members.length;
const label = `Also appears in ${n} other ${n === 1 ? "agency" : "agencies"} — show which`;
---

<span class="reuse">
  <button type="button" class="reuse__trigger" aria-label={label}>
    <span aria-hidden="true">{n}</span>
  </button>
  <span class="reuse__panel" role="note">
    <span class="reuse__head">Also appears in {n} other {n === 1 ? "agency" : "agencies"}</span>
    <span class="reuse__pills">
      {
        members.map((m) => (
          <a class="pill reuse__pill" href={statementPath(m.abbr)} title={m.name}>
            {m.abbr}
          </a>
        ))
      }
    </span>
  </span>
</span>

<style>
  .reuse {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }

  /* the chip itself: a quiet superscript count that warms on interaction */
  .reuse__trigger {
    appearance: none;
    cursor: pointer;
    font: inherit;
    font-size: 0.62em;
    font-weight: 700;
    line-height: 1;
    vertical-align: super;
    margin-inline-start: 0.15em;
    padding: 0.18em 0.42em;
    border: 1px solid color-mix(in oklab, var(--accent) 40%, var(--border));
    border-radius: 999px;
    color: var(--accent-ink);
    background: var(--bg);
    font-variant-numeric: tabular-nums;
    transition:
      background var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart);
  }

  .reuse__trigger::before {
    content: "+";
  }

  .reuse:hover .reuse__trigger,
  .reuse__trigger:focus-visible {
    background: var(--accent);
    color: var(--accent-contrast);
    outline: none;
  }

  .reuse__trigger:focus-visible {
    outline: 2px solid var(--accent-ink);
    outline-offset: 2px;
  }

  /* the panel: hidden until the chip (or panel) is hovered/focused */
  .reuse__panel {
    position: absolute;
    inset-inline-end: 0;
    inset-block-start: calc(100% + 0.4rem);
    z-index: 20;
    inline-size: max-content;
    max-inline-size: min(22rem, 84vw);
    padding: var(--space-3);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    background: var(--bg);
    box-shadow: var(--shadow-lg);
    white-space: normal;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-0.25rem);
    transition:
      opacity var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart),
      visibility var(--dur-fast);
  }

  /* an invisible bridge across the gap so the pointer can travel chip → panel
     without the hover dropping */
  .reuse__panel::before {
    content: "";
    position: absolute;
    inset-block-start: -0.4rem;
    inset-inline: 0;
    block-size: 0.4rem;
  }

  .reuse:hover .reuse__panel,
  .reuse:focus-within .reuse__panel {
    opacity: 1;
    visibility: visible;
    transform: none;
  }

  .reuse__head {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-block-end: var(--space-2);
  }

  .reuse__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    max-block-size: 14rem;
    overflow-y: auto;
  }

  a.reuse__pill {
    text-decoration: none;
    color: var(--accent-ink);
    background: var(--surface);
    transition:
      background var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart);
  }

  a.reuse__pill:hover,
  a.reuse__pill:focus-visible {
    background: var(--accent-wash);
    border-color: color-mix(in oklab, var(--accent) 50%, var(--border));
    outline: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .reuse__panel {
      transition: none;
      transform: none;
    }
  }
</style>
