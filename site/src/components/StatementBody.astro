---
import { marked } from "marked";
import { heatLevel } from "@/lib/format";
import ReuseChip from "@/components/ReuseChip.astro";
import type { PassageRow } from "@/types/exporter";

interface Member {
  abbr: string;
  name: string;
}

interface Props {
  passages: PassageRow[];
  // Other agencies sharing each passage, keyed by normKey (excludes this one).
  sharedBy?: Record<string, Member[]>;
}

const { passages, sharedBy = {} } = Astro.props;

type Item = { html: string; heat: number; tip: string; share: Member[] };
type Block =
  | { kind: "list"; items: Item[] }
  | { kind: "heading"; level: number; html: string; heat: number; tip: string; share: Member[] }
  | { kind: "para"; html: string; heat: number; tip: string; share: Member[] };

function stripMarker(raw: string): string {
  return raw.replace(/^\s*(?:[-*+]|\d+\.|#{1,6})\s*/, "");
}

// Statement text is scraped from agency sites, so harden the markdown → HTML
// step before it reaches set:html: drop any raw HTML tags from the source (the
// pattern skips `<https://…>` autolinks), then neutralise non-http(s) link
// schemes that marked might still emit from a markdown link.
function stripTags(raw: string): string {
  return raw.replace(/<\/?[a-z][a-z0-9]*(?:\s[^>]*)?\/?>/gi, "");
}

function inline(raw: string): string {
  const html = marked.parseInline(stripMarker(stripTags(raw))) as string;
  return html.replace(/\b(href|src)\s*=\s*(["'])\s*(?:javascript|data|vbscript):/gi, "$1=$2#");
}

function heat(p: PassageRow): number {
  return heatLevel(p.sharedCount, p.containsCanonicalPhrase);
}

function tip(p: PassageRow): string {
  if (p.sharedCount >= 2) {
    const others = p.sharedCount - 1;
    return `Shared with ${others} other ${others === 1 ? "agency" : "agencies"}`;
  }
  return p.containsCanonicalPhrase ? "Template language" : "Unique to this statement";
}

function item(p: PassageRow): Item {
  return { html: inline(p.rawText), heat: heat(p), tip: tip(p), share: sharedBy[p.normKey] ?? [] };
}

// Demote statement headings to sit under the page <h1>, normalising so the
// shallowest heading becomes <h2> — avoids an h1 → h3 jump when a scraped
// statement starts at "##".
const headingDepths = passages
  .filter((p) => p.kind === "heading")
  .map((p) => /^(#{1,6})/.exec(p.rawText)?.[1].length ?? 1);
const headingOffset = headingDepths.length ? 2 - Math.min(...headingDepths) : 1;

const blocks: Block[] = [];
let i = 0;
while (i < passages.length) {
  const p = passages[i];
  if (p.kind === "list_item") {
    const items: Item[] = [];
    while (i < passages.length && passages[i].kind === "list_item") {
      items.push(item(passages[i]));
      i++;
    }
    blocks.push({ kind: "list", items });
  } else if (p.kind === "heading") {
    const hashes = /^(#{1,6})/.exec(p.rawText);
    const raw = hashes ? hashes[1].length : 1;
    const level = Math.min(Math.max(raw + headingOffset, 2), 6);
    blocks.push({
      kind: "heading",
      level,
      html: inline(p.rawText),
      heat: heat(p),
      tip: tip(p),
      share: sharedBy[p.normKey] ?? [],
    });
    i++;
  } else {
    blocks.push({
      kind: "para",
      html: inline(p.rawText),
      heat: heat(p),
      tip: tip(p),
      share: sharedBy[p.normKey] ?? [],
    });
    i++;
  }
}
---

<div class="statement-body prose">
  {
    blocks.map((b) => {
      if (b.kind === "list") {
        return (
          <ul>
            {b.items.map((it) => (
              <li class="heat" data-heat={it.heat} title={it.share.length ? undefined : it.tip}>
                <span set:html={it.html} />
                {it.share.length ? (
                  <ReuseChip members={it.share} />
                ) : (
                  it.heat >= 1 && <span class="visually-hidden"> ({it.tip})</span>
                )}
              </li>
            ))}
          </ul>
        );
      }
      if (b.kind === "heading") {
        const Tag = `h${b.level}` as "h2";
        return (
          <Tag class="heat" data-heat={b.heat} title={b.share.length ? undefined : b.tip}>
            <span set:html={b.html} />
            {b.share.length ? (
              <ReuseChip members={b.share} />
            ) : (
              b.heat >= 1 && <span class="visually-hidden"> ({b.tip})</span>
            )}
          </Tag>
        );
      }
      return (
        <p class="heat" data-heat={b.heat} title={b.share.length ? undefined : b.tip}>
          <span set:html={b.html} />
          {b.share.length ? (
            <ReuseChip members={b.share} />
          ) : (
            b.heat >= 1 && <span class="visually-hidden"> ({b.tip})</span>
          )}
        </p>
      );
    })
  }
</div>
