---
import { meta, getAgencies, propagation } from "@/lib/load";
import { formatDate, originalityPercent } from "@/lib/format";
import { statementPath } from "@/lib/paths";

const agencies = await getAgencies();
const c = meta.counts;
const published = agencies.filter((a) => a.statementId);
const mostRevised = [...published].sort((a, b) => b.revisionCount - a.revisionCount)[0];
const board = propagation.originality;
const leastOriginal = board[board.length - 1];
const since = meta.firstCommit ? formatDate(meta.firstCommit) : "launch";

const facts = [
  { label: "Published", value: `${c.published} of ${c.agencies}`, href: null },
  { label: "Not yet", value: String(c.notYet), href: null },
  { label: "Exempt", value: String(c.exempt), href: null },
  {
    label: "Most revised",
    value: `${mostRevised.abbr} · ${mostRevised.revisionCount}`,
    href: statementPath(mostRevised.abbr),
  },
  {
    label: "Most templated",
    value: `${leastOriginal.abbr} · ${originalityPercent(leastOriginal.score)}% bespoke`,
    href: statementPath(leastOriginal.abbr),
  },
];
---

<section class="coverage" aria-label="Coverage at a glance">
  <p class="coverage__lead">
    <span class="coverage__big mono">{c.revisions}</span>
    <span class="coverage__gloss">
      changes tracked since {since}, across <strong>{c.published}</strong> published
      statements from {c.agencies} agencies on the APSC list.
    </span>
  </p>

  <dl class="coverage__facts">
    {
      facts.map((f) => (
        <div class="coverage__fact">
          <dt>{f.label}</dt>
          <dd>{f.href ? <a href={f.href}>{f.value}</a> : f.value}</dd>
        </div>
      ))
    }
  </dl>
</section>

<style>
  .coverage {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-block: var(--space-2);
  }

  .coverage__lead {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-4);
  }

  .coverage__big {
    font-size: clamp(3rem, 2rem + 5vw, 5rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  .coverage__gloss {
    flex: 1 1 14rem;
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1.4;
    text-wrap: pretty;
  }

  .coverage__gloss strong {
    color: var(--text);
    font-weight: 700;
  }

  .coverage__facts {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(7.5rem, 1fr));
    gap: var(--space-4) var(--space-5);
    border-block-start: 2px solid var(--border-strong);
    padding-block-start: var(--space-4);
  }

  .coverage__fact dt {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin-block-end: 0.15rem;
  }

  .coverage__fact dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 1.02rem;
    font-weight: 600;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
</style>
